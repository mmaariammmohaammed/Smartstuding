# =============================================================================
# SMARTSTUDY FRONTEND - ENVIRONMENT CONFIGURATION
# =============================================================================
# File: /smartstudy-frontend/.env
# Last Updated: 2026-05-23
#
# INSTRUCTIONS:
# 1. Copy this file to /smartstudy-frontend/.env
# 2. Must use VITE_ prefix for all variables (Vite requirement)
# 3. Restart dev server after changes: npm run dev
# 4. NEVER commit .env to git
# =============================================================================

# ------------------------------------------------------------------------------
# API CONFIGURATION [REQUIRED]
# ------------------------------------------------------------------------------
# Must match your backend URL
# Development (local):
VITE_API_URL=http://localhost:5000/api/v1

# Production (example):
# VITE_API_URL=https://api.smartstudy.com/api/v1

# ------------------------------------------------------------------------------
# APP CONFIGURATION
# ------------------------------------------------------------------------------
VITE_APP_NAME=SmartStudy
VITE_APP_VERSION=1.0.0

# ------------------------------------------------------------------------------
# FEATURE FLAGS (Enable/Disable features)
# ------------------------------------------------------------------------------
# Set to 'true' to enable Stripe payments
VITE_ENABLE_STRIPE=false

# Set to 'true' to enable AI features
VITE_ENABLE_AI=true

# Set to 'true' to show debug info
VITE_DEBUG_MODE=false
