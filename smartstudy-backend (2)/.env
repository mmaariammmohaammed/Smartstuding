# =============================================================================
# SMARTSTUDY BACKEND - PRODUCTION-READY ENVIRONMENT CONFIGURATION
# =============================================================================
# File: /smartstudy-backend/.env
# 
# ⚠️  IMPORTANT: 
# - This file contains secrets. NEVER commit to git.
# - Add .env to your .gitignore file.
# - Change JWT secrets before deploying to production.
# =============================================================================

# ------------------------------------------------------------------------------
# CORE SERVER CONFIGURATION [REQUIRED]
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# ------------------------------------------------------------------------------
# MONGODB ATLAS CONNECTION [REQUIRED]
# ------------------------------------------------------------------------------
# Your MongoDB Atlas URI (pre-configured with your credentials)
# Database: smartstudy
# Includes: retryWrites=true, w=majority for data safety
# Includes: appName=Smartstudy for Atlas monitoring
MONGODB_URI=mongodb+srv://itsmariam461_db_user:m.2626@smartstudy.vapaqxw.mongodb.net/smartstudy?retryWrites=true&w=majority&appName=Smartstudy

# ------------------------------------------------------------------------------
# JWT AUTHENTICATION SECRETS [REQUIRED - CHANGE IN PRODUCTION!]
# ------------------------------------------------------------------------------
# These are pre-filled with secure defaults for development.
# For production, generate new secrets with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=smartstudy_jwt_dev_secret_2026_do_not_use_in_production_7a3f9e2d1b8c4e5f6a0d9e8b7c6f5a4d3e2b1c0f9a8b7c6d5e4f3a2b1c0d9e8f7a6b5c4d3e2f1a0b9c8d7e6f5a4b3c2d1e0f9a8b7
JWT_REFRESH_SECRET=smartstudy_refresh_dev_secret_2026_change_for_prod_1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ------------------------------------------------------------------------------
# FRONTEND CORS CONFIGURATION [REQUIRED]
# ------------------------------------------------------------------------------
# Must match your frontend URL exactly (including port)
# For local development:
CLIENT_URL=http://localhost:5173

# For production (example):
# CLIENT_URL=https://smartstudy.vercel.app

# ------------------------------------------------------------------------------
# STRIPE PAYMENT INTEGRATION [OPTIONAL - Safe to leave empty]
# ------------------------------------------------------------------------------
# Leave ALL empty to disable Stripe (mock mode will be used automatically)
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ------------------------------------------------------------------------------
# EMAIL / SMTP CONFIGURATION [OPTIONAL - Safe to leave empty]
# ------------------------------------------------------------------------------
# Leave SMTP_USER and SMTP_PASS empty to disable email (console logging only)
# For Gmail: Use App Password (NOT your regular Gmail password!)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ------------------------------------------------------------------------------
# AI SERVICE CONFIGURATION [OPTIONAL - Safe to leave empty]
# ------------------------------------------------------------------------------
# OpenAI API Key (for GPT-based study recommendations)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API Key (alternative AI provider)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ------------------------------------------------------------------------------
# ADVANCED CONFIGURATION (Defaults are usually fine - don't change unless needed)
# ------------------------------------------------------------------------------
# Bcrypt salt rounds (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=12

# Request body size limits
MAX_REQUEST_SIZE=10mb

# Rate limiting window (15 minutes in milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window
RATE_LIMIT_MAX_REQUESTS=100

# Logging level: error | warn | info | debug
LOG_LEVEL=debug
